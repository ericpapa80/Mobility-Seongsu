# ============================================
# 공통 환경 변수 (프론트엔드 + 백엔드 공유)
# ============================================

# PostgreSQL + PostGIS (Railway provides this automatically)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mobility_seongsu

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# API Base URL (frontend → backend)
VITE_API_BASE_URL=http://localhost:8000

# Mapbox API (프론트엔드와 백엔드 모두 사용)
VITE_MAPBOX_TOKEN=
MAPBOX_TOKEN=

# 공공데이터 포털 API
PUBLIC_DATA_KEY=

# 서울열린데이터광장 API (분당선 등 CardSubwayTime)
SEOUL_OPEN_DATA_KEY=

# 서울시 버스 API (ws.bus.go.kr, 1단계 정류장/경유노선 조회)
# 공공데이터포털 서울특별시_정류소정보조회(15000303) 활용신청
SEOUL_BUS_API_KEY=

# OpenAI API
VITE_OPENAI_API_KEY=

# SGIS API
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=
SGIS_FUSION_ACCESS_TOKEN=

# SBIZ API (소상공인시장진흥공단)
SBIZ_SERVICE_KEY=

# NPS API (국민연금공단)
NPS_SERVICE_KEY=

# Naver local Search API Keys
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Kakao API
KAKAO_API_KEY=

# Vworld API
VWORLD_API_KEY=
vworld_domain=http://localhost

# 건축Hub API
건축Hub_API_KEY=

# OpenRouteService API
ORS_API_KEY=

# n8n API
N8N_URL=http://localhost:5678
N8N_API_KEY=
VITE_N8N_API_KEY=

# SK OPEN API - Puzzle
PUZZLE-SUBWAY_API_KEY=

